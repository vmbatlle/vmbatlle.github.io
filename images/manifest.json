---
layout: none
permalink: /images/manifest.json
---
{
	"name": {{ site.title | jsonify }},
	"short_name": {{ site.name | jsonify }},
	"description": {{ site.description | jsonify }},
	"start_url": "{{ site.baseurl | default: '/' }}",
	"lang": {{ site.locale | default: "en" | jsonify }},
	"icons": [
		{
			"src": "{{ site.favicon.192x192 | default: '/images/favicon-192x192.png' }}",
			"sizes": "192x192",
			"type": "image/png"
		},
		{
			"src": "{{ site.favicon.512x512 | default: '/images/favicon-512x512.png' }}",
			"sizes": "512x512",
			"type": "image/png"
		}
	]
}